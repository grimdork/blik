build: go
desc=Build the blik binary

linux: go
desc=Build the Linux binary
arch=amd64
os=linux

blik: oci:scw
desc=Build and push the OCI image
require=linux
region=nl-ams
tag=latest
cacert=auto
entrypoint=/app/blik
arch=amd64
os=linux

vet:
desc=Run go vet
cmd=go vet ./...

test:
desc=Run tests
require=vet
cmd=go test ./...
