$LDFLAGS=-s -w -X main.version=$(git describe --tags --always 2>/dev/null || echo dev) -X main.commit=$(git rev-parse --short HEAD) -X main.date=$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || echo unknown)

build: go
    desc=Build the blik binary
    cmd=go build -ldflags="$LDFLAGS" -o $bin

image: oci
    desc=Build OCI image
    require=build
    repo=ghcr.io/blik
    tag=latest
    cacert=auto
    entrypoint=/app/blik

vet:
    desc=Run go vet
    cmd=go vet ./...

test:
    desc=Run tests
    require=vet
    cmd=go test ./...
